#pragma once

#include <rocm/dnn.hpp>
#include <rocm_creation_context.hpp>

#include "gru_sequence_components.hpp"

namespace ov::rocm_gpu::RNN::Details {

/**
 * @brief Presents GRU Sequence parameters in a form suitable for miopen API.
 *        Represents parameters from ngraph.
 */
class GRUSequenceParamsmiopen {
public:
    GRUSequenceParamsmiopen(const GRUSequenceParams& params);

    miopenDataType_t element_type_;
    rocmDataType_t element_type_rocm_;
    size_t element_size_;
    miopenDirectionMode_t direction_;
    bool linear_before_reset_;

    int32_t batch_size_;
    int32_t max_seq_length_;
    int32_t input_size_;
    int32_t hidden_size_;

    gsl::span<const uint8_t> w_host_buffers_;
    gsl::span<const uint8_t> r_host_buffers_;
    gsl::span<const uint8_t> b_host_buffers_;

    std::vector<int32_t> seq_length_array_;

    int32_t numDirections() const { return direction_ == miopen_BIDIRECTIONAL ? 2 : 1; }
    int32_t projSize() const { return hidden_size_; }
};

/**
 * @brief Prepares all data required for miopen LSTM Sequence API invocation.
 */
class GRUSequenceDescriptorsmiopen {
public:
    using DevPtr = rocm::DevicePointer<void*>;

    /// @brief Implementation specific configuration.
    struct Config {
        miopenRNNDataLayout_t rnn_data_layout{miopen_RNN_DATA_LAYOUT_BATCH_MAJOR_UNPACKED};
    };

    GRUSequenceDescriptorsmiopen(const CreationContext& context,
                                const GRUSequenceParamsmiopen& params,
                                const Config& config);

    miopenRNNFWDMode_t  dnnForwardMode() const { return miopen_FWD_MODE_INFERENCE; }

    const rocm::DnnRnnDescriptor& rnnDesc() const { return rnn_desc_; }
    const rocm::DnnRnnDataDescriptor& xDesc() const { return x_desc_; }
    const rocm::DnnRnnDataDescriptor& yDesc() const { return y_desc_; }
    const rocm::DnnTensorDescriptor& hDesc() const { return h_desc_; }

    size_t seqLengthArraySizeBytes() const { return params_.seq_length_array_.size() * sizeof(int32_t); }
    void initDevSeqLengthArray(DevPtr buffer);

    size_t weightSpaceSize() const { return weight_space_size_; }
    void initWeightSpace(DevPtr buffer);

    size_t workSpaceSize() const { return work_space_size_; }

private:
    void createRNNDescriptor(const CreationContext& context);
    void createXDescriptor();
    void createYDescriptor();
    void createHDescriptor();

    bool weightBuffersFit(DevPtr buffer) const;
    void calculateWeightBuffers(DevPtr buffer);

private:
    const GRUSequenceParamsmiopen& params_;
    const Config config_;

    rocm::DnnRnnDescriptor rnn_desc_;
    rocm::DnnRnnDataDescriptor x_desc_;
    rocm::DnnRnnDataDescriptor y_desc_;
    rocm::DnnTensorDescriptor h_desc_;

    size_t weight_space_size_;
    size_t work_space_size_;

    using DevBuffers = std::vector<rocm::DeviceBuffer<uint8_t>>;
    DevBuffers w_dev_buffers_;
    DevBuffers r_dev_buffers_;
    DevBuffers b1_dev_buffers_;
    DevBuffers b2_dev_buffers_;
};

}  // namespace ov::rocm_gpu::RNN::Details
