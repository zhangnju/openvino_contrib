#include <fmt/format.h>

#include <openvino/core/except.hpp>
#include <sstream>

#include <hip/hip_runtime.h>
#include "add_miopen.hpp"
#include "add_rocm.hpp"
#include "rocm_operation_registry.hpp"

namespace ov {
namespace rocm_gpu {

// No-op Add: used when computation is already handled upstream (pe(V)+attn fusion).
// The AV MatMul fused kernel already writes pe(V)+attn to its output buffer,
// which is aliased to this Add's output. Execute does a D2D copy of input[1]
// (AV MatMul output = attn_out) to output, effectively a passthrough.
class NoOpAddOp : public OperationBase {
public:
    size_t out_bytes_;
    int av_input_idx_;  // Add input index that comes from the AV (attn) path

    NoOpAddOp(const CreationContext& ctx, const ov::Node& node,
              IndexCollection&& inputs, IndexCollection&& outputs)
        : OperationBase(ctx, node, std::move(inputs), std::move(outputs))
        , av_input_idx_(1) {  // default: input[1] is the attn path
        const auto out_shape = node.get_output_shape(0);
        size_t n = 1;
        for (auto d : out_shape) n *= d;
        out_bytes_ = n * node.get_output_element_type(0).size();
        // Read which input index comes from the AV (attn) path
        const auto& rt = node.get_rt_info();
        auto it = rt.find("rocm_pe_av_input_idx");
        if (it != rt.end()) {
            try { av_input_idx_ = std::stoi(it->second.as<std::string>()); } catch (...) {}
        }
    }

    void Execute(const InferenceRequestContext& ctx,
                 Inputs inputs, Outputs outputs, const Workbuffers&) const override {
        // The pe fused kernel already wrote pe(V)+attn to the AV output buffer.
        // The buffer planner should alias this Add's output to that same buffer.
        // If they're the same pointer, this is a true no-op. Otherwise D2D copy.
        OPENVINO_ASSERT(outputs.size() == 1);
        void* dst = outputs[0].get();
        // Check if any input is already the output buffer (in-place, no copy needed)
        for (size_t i = 0; i < inputs.size(); ++i) {
            if (inputs[i].get() == dst) return;
        }
        // Copy from the AV-path input (contains pe+attn result) to output
        const int idx = (av_input_idx_ < static_cast<int>(inputs.size())) ? av_input_idx_ : 0;
        hipMemcpyAsync(dst, inputs[idx].get(), out_bytes_,
                      hipMemcpyDeviceToDevice,
                      ctx.getThreadContext().stream().get());
    }
    rocmGraphCompatibility GetrocmGraphCompatibility() const override { return rocmGraphCompatibility::FULL; }
};

static OperationBase::Ptr addFactory(const CreationContext& context,
                                     const std::shared_ptr<ov::Node>& in_node,
                                     OperationBase::IndexCollection&& inputIds,
                                     OperationBase::IndexCollection&& outputIds) {
    auto node = std::dynamic_pointer_cast<ov::op::v1::Add>(in_node);
    OPENVINO_ASSERT(node);

    // pe+attn Add is a passthrough (pe fused kernel handles the computation)
    if (in_node->get_rt_info().count("rocm_pe_add_noop")) {
        return std::make_shared<NoOpAddOp>(context, *in_node,
            OperationBase::IndexCollection{inputIds}, OperationBase::IndexCollection{outputIds});
    }
    // (old disabled comment follows)
    // if (in_node->get_rt_info().count("rocm_pe_add_noop_disabled")) {
    //     return std::make_shared<NoOpAddOp>(context, *in_node, ...);
    // }

    const OperationBase::IndexCollection inputs{inputIds};
    const OperationBase::IndexCollection outputs{outputIds};

    std::stringstream exception_msg;
    // Custom HIP kernel first: avoids miopenOpTensor() → Op5dTensorGeneric overhead.
    // MIOpen's generic tensor-op path is slower than the vectorized hipRTC kernel.
    try {
        return std::make_shared<AddrocmOp>(
            context, *node, OperationBase::IndexCollection{inputs}, OperationBase::IndexCollection{outputs});
    } catch (const std::exception& e) {
        exception_msg << "Failed to create Addrocm impl: " << e.what();
    }
    try {
        return std::make_shared<AddmiopenOp>(
            context, node, OperationBase::IndexCollection{inputs}, OperationBase::IndexCollection{outputs});
    } catch (const std::exception& e) {
        exception_msg << "\nFailed to create Addmiopen impl: " << e.what();
    }
    throw_ov_exception(fmt::format("Add node is not supported:\n{}", exception_msg.str()));
}

OPERATION_REGISTER_FACTORY(addFactory, Add)

}  // namespace rocm_gpu
}  // namespace ov
