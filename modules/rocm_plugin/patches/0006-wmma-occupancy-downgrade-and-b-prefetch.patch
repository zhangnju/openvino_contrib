-        Value bufferB = adaptor.getBufferB();
-        bufferB =
-            loadBuffer(bufferB, wrappedLDSBufferForLoadB, j, argTypeB, nRepeats,
-                       loadBFromLDS, matrixParamsB.getDirectToLDS(), false,
-                       transposeAttrB);
-        Value viewB =
-            accelEmitterPtr->generateThreadwiseViewBufferB(b, loc, bufferB);
-        if (isScaledGemm) {
-          if (matrixParamsB.getDirectToLDS()) {
-            op->emitOpError("Direct to LDS scaled GEMM is not supported yet.");
-            return failure();
+      // Prefetch optimization: when nRepeats is small (<=4), load ALL B tiles
+      // from LDS before doing ANY WMMA. This separates ds_load from v_wmma,
+      // allowing the LLVM backend to hide LDS latency without s_waitcnt
+      // between each load-compute pair.
+      // Original: for n { load_B[n]; WMMA(A,B[n],C[n]) }  ← load/compute interleaved
+      // Optimized: load_B[0..N]; for n { WMMA(A,B[n],C[n]) }  ← loads batched
+      if (nRepeats <= 4 && nRepeats > 1 && !isScaledGemm) {
+        // Phase 1: Load all B tiles into separate register buffers
+        SmallVector<Value> allBufferB(nRepeats);
+        SmallVector<Value> allViewB(nRepeats);
+        for (int64_t n = 0; n < nRepeats; ++n) {
+          Value jConst = b.createOrFold<arith::ConstantIndexOp>(loc, n);
+          Value bufB = adaptor.getBufferB();
+          bufB = loadBuffer(
+              bufB, wrappedLDSBufferForLoadB, jConst, argTypeB, nRepeats,
+              loadBFromLDS, matrixParamsB.getDirectToLDS(), false,
+              transposeAttrB);
+          allBufferB[n] = bufB;
+          allViewB[n] = accelEmitterPtr->generateThreadwiseViewBufferB(
+              b, loc, bufB);
+        }
+        // Phase 2: Compute all WMMAs using pre-loaded B tiles
+        for (int64_t n = 0; n < nRepeats; ++n) {
+          Value jConst = b.createOrFold<arith::ConstantIndexOp>(loc, n);
+          auto kLoop = affine::AffineForOp::create(b, loc, 0, kBasePerThread);
+          {
+            OpBuilder::InsertionGuard guard(b);
+            b.setInsertionPointToStart(kLoop.getBody());
+            Value viewC = accelEmitterPtr->generateThreadwiseViewBufferC(
+                b, loc, adaptor.getMatrixC());
+            Value k = kLoop.getInductionVar();
+            ThreadwiseGemmAccelOp::create(b, loc, viewA, allViewB[n], viewC,
+                                          viewScaleA, viewScaleB,
+                                          ValueRange{i, jConst, k},
+                                          op.getFeaturesAttr(), tuningParams);
           }
-          Value bufferScaleB = adaptor.getBufferScaleB();
-          bufferScaleB =
-              loadBuffer(bufferScaleB, wrappedLDSBufferForScaleB, j,
-                         getElementTypeOrSelf(scaleB), nRepeats, loadBFromLDS,
-                         matrixParamsB.getDirectToLDS(), false, nullptr);
-          viewScaleB = accelEmitterPtr->generateThreadwiseViewBufferB(
-              b, loc, bufferScaleB);
         }
-
-        // regsC += regsA * regsB
-        auto kLoop = affine::AffineForOp::create(b, loc, 0, kBasePerThread);
+      } else {
+        // Original path: interleaved load/compute (for large nRepeats or scaled GEMM)
+        auto nLoop = affine::AffineForOp::create(b, loc, 0, nRepeats);
         {
           OpBuilder::InsertionGuard guard(b);
-          b.setInsertionPointToStart(kLoop.getBody());
-          Value viewC = accelEmitterPtr->generateThreadwiseViewBufferC(
-              b, loc, adaptor.getMatrixC());
-          Value k = kLoop.getInductionVar();
-          ThreadwiseGemmAccelOp::create(b, loc, viewA, viewB, viewC, viewScaleA,
-                                        viewScaleB, ValueRange{i, j, k},
-                                        op.getFeaturesAttr(), tuningParams);
+          b.setInsertionPointToStart(nLoop.getBody());
+          Value j = nLoop.getInductionVar();
+
+          Value bufferB = adaptor.getBufferB();
+          bufferB =
+              loadBuffer(bufferB, wrappedLDSBufferForLoadB, j, argTypeB, nRepeats,
+                         loadBFromLDS, matrixParamsB.getDirectToLDS(), false,
+                         transposeAttrB);
+          Value viewB =
+              accelEmitterPtr->generateThreadwiseViewBufferB(b, loc, bufferB);
+          if (isScaledGemm) {
+            if (matrixParamsB.getDirectToLDS()) {
+              op->emitOpError("Direct to LDS scaled GEMM is not supported yet.");
+              return failure();
+            }
+            Value bufferScaleB = adaptor.getBufferScaleB();
+            bufferScaleB =
+                loadBuffer(bufferScaleB, wrappedLDSBufferForScaleB, j,
+                           getElementTypeOrSelf(scaleB), nRepeats, loadBFromLDS,
+                           matrixParamsB.getDirectToLDS(), false, nullptr);
+            viewScaleB = accelEmitterPtr->generateThreadwiseViewBufferB(
+                b, loc, bufferScaleB);
+          }
+
+          // regsC += regsA * regsB
+          auto kLoop = affine::AffineForOp::create(b, loc, 0, kBasePerThread);
+          {
+            OpBuilder::InsertionGuard guard(b);
+            b.setInsertionPointToStart(kLoop.getBody());
+            Value viewC = accelEmitterPtr->generateThreadwiseViewBufferC(
+                b, loc, adaptor.getMatrixC());
+            Value k = kLoop.getInductionVar();
+            ThreadwiseGemmAccelOp::create(b, loc, viewA, viewB, viewC, viewScaleA,
+                                          viewScaleB, ValueRange{i, j, k},
+                                          op.getFeaturesAttr(), tuningParams);
+          }
         }
       }
     }
diff --git a/mlir/lib/Dialect/Rock/Transforms/GridwiseGemmToBlockwise.cpp b/mlir/lib/Dialect/Rock/Transforms/GridwiseGemmToBlockwise.cpp
index f2fd9009f89f..5a445a196fbe 100644
--- a/mlir/lib/Dialect/Rock/Transforms/GridwiseGemmToBlockwise.cpp
+++ b/mlir/lib/Dialect/Rock/Transforms/GridwiseGemmToBlockwise.cpp
@@ -2983,6 +2983,35 @@ struct GridwiseGemmAccelRewritePattern
       return op.emitOpError("schedule version value is incorrect");
 
     auto loadType = maybeLoadType.value();
+
+    // Occupancy-aware schedule downgrade: if double-buffering would push
+    // VGPR usage beyond the occupancy threshold, fall back to single-buffer.
+    // gfx1100 WMMA: double-buffering multiplies input registers by mRepeats/nRepeats,
+    // which can add 30-50 VGPRs and drop occupancy from 81% to 62%.
+    if (loadType == GemmLoadTileType::DoubleBuffer &&
+        bitEnumContainsAll(features, GemmFeatures::wmma)) {
+      int64_t dPerAccel = 16;
+      int64_t mPerWave = tuningParams.getMPerWave();
+      int64_t nPerWave = tuningParams.getNPerWave();
+      int64_t mRepeats = mPerWave / dPerAccel;
+      int64_t nRepeats = nPerWave / dPerAccel;
+      int64_t accVgprs = 8 * mRepeats * nRepeats;
+      int64_t inputVecLen = 16;
+      int64_t kBase = std::max(int64_t(1), kPerBlock / inputVecLen);
+      // Double-buffer inflates input regs by mRepeats (A) and nRepeats (B)
+      int64_t dbInputVgprs = (kBase * inputVecLen * mRepeats +
+                              kBase * inputVecLen * nRepeats) / 2;
+      int64_t copyVgprs = (aCopyPerThread + bCopyPerThread) / 2;
+      int64_t estVgprs = accVgprs + dbInputVgprs + copyVgprs + 16;
+      // 1536 VGPRs / SIMD, target >= 10 waves (62.5%) — only downgrade for
+      // extreme pressure (< 8 waves = 50%)
+      if (1536 / std::max(estVgprs, int64_t(1)) < 8) {
+        loadType = GemmLoadTileType::Default;
+        LLVM_DEBUG(llvm::dbgs() << "Downgrading to single-buffer: estVGPR="
+                                << estVgprs << " → occupancy too low\n");
+      }
+    }
+
     bool directToLDS = loadType == GemmLoadTileType::DirectToLDSDefault ||
                        loadType == GemmLoadTileType::DirectToLDSDoubleBuffer;
 
